 void poweroff (void)
 {
+#if RASPPI == 4
+	PeripheralEntry ();
+
+	// Partition 63 tells the Raspberry Pi bootloader to enter HALT instead
+	// of loading another kernel after the watchdog reset.
+	u32 nRSTS = read32 (ARM_PM_RSTS);
+	nRSTS &= ARM_PM_RSTS_PART_CLEAR;
+	nRSTS |= ARM_PM_PASSWD | 0x555;
+	write32 (ARM_PM_RSTS, nRSTS);
+
+	write32 (ARM_PM_WDOG, ARM_PM_PASSWD | 10);
+
+	u32 nRSTC = read32 (ARM_PM_RSTC);
+	nRSTC &= ARM_PM_RSTC_CLEAR;
+	nRSTC |= ARM_PM_PASSWD | ARM_PM_RSTC_REBOOT;
+	write32 (ARM_PM_RSTC, nRSTC);
