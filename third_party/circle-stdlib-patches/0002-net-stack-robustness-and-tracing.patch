+static const char *DHCPTraceTypeName (unsigned nType)
+{
+	switch (nType)
+	{
+	case DHCP_OPTION_MSGTYPE_DISCOVER:
+		return "DISCOVER";
+	case DHCP_OPTION_MSGTYPE_OFFER:
+		return "OFFER";
+	case DHCP_OPTION_MSGTYPE_REQUEST:
+		return "REQUEST";
+	case DHCP_OPTION_MSGTYPE_DECLINE:
+		return "DECLINE";
+	case DHCP_OPTION_MSGTYPE_ACK:
+		return "ACK";
+	case DHCP_OPTION_MSGTYPE_NAK:
+		return "NAK";
+	case DHCP_OPTION_MSGTYPE_RELEASE:
