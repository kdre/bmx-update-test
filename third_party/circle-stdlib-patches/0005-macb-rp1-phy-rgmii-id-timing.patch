+void CMACBDevice::phy_config_rgmii_id (void)
+{
+	u16 aux = phy_read_auxctl (MII_BCM54XX_AUXCTL_SHDWSEL_MISC);
+	aux |=   MII_BCM54XX_AUXCTL_MISC_WREN
+	       | MII_BCM54XX_AUXCTL_SHDWSEL_MISC_RGMII_EN
+	       | MII_BCM54XX_AUXCTL_SHDWSEL_MISC_RGMII_SKEW_EN
+	       | MII_BCM54XX_AUXCTL_SHDWSEL_MISC_RSVD;
+	phy_write_auxctl (MII_BCM54XX_AUXCTL_SHDWSEL_MISC, aux);
+
+	u16 clk = phy_read_shadow (BCM54810_SHD_CLK_CTL);
+	clk |= BCM54810_SHD_CLK_CTL_GTXCLK_EN;
+	phy_write_shadow (BCM54810_SHD_CLK_CTL, clk);
+
+	LOGDBG ("PHY RGMII-ID aux 0x%04x clk 0x%04x", aux, clk);
+}
+
+u16 CMACBDevice::phy_read_auxctl (u16 regnum)
+{
+	mdio_write (m_phy_addr, MII_BCM54XX_AUX_CTL,
+		    MII_BCM54XX_AUXCTL_SHDWSEL_MASK
+		  | (regnum << MII_BCM54XX_AUXCTL_SHDWSEL_READ_SHIFT));
+
+	return mdio_read (m_phy_addr, MII_BCM54XX_AUX_CTL);
+}
+
+void CMACBDevice::phy_write_auxctl (u16 regnum, u16 val)
+{
+	mdio_write (m_phy_addr, MII_BCM54XX_AUX_CTL, regnum | val);
+}
+
+u16 CMACBDevice::phy_read_shadow (u16 shadow)
+{
+	mdio_write (m_phy_addr, MII_BCM54XX_SHD, MII_BCM54XX_SHD_VAL (shadow));
+
+	return MII_BCM54XX_SHD_DATA (mdio_read (m_phy_addr, MII_BCM54XX_SHD));
+}
