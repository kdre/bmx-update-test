+	case DHCP_OPTION_MSGTYPE_INFORM:
+		return "INFORM";
+	default:
+		return "UNKNOWN";
+	}
+}
+
+static unsigned DHCPTraceOptionU8 (const u8 *pOptions, unsigned nOptionsSize, u8 uchCode)
+{
+	assert (pOptions != 0);
+
+	for (unsigned i = 0; i < nOptionsSize;)
+	{
+		u8 uchOption = pOptions[i];
+		if (uchOption == DHCP_OPTION_END)
+		{
+			break;
+		}
+		if (uchOption == DHCP_OPTION_PAD)
+		{
+			i++;
+			continue;
+		}
+		if (i+2 > nOptionsSize)
+		{
+			break;
+		}
+
+		unsigned nLen = pOptions[i+1];
+		if (i+2+nLen > nOptionsSize)
+		{
+			break;
+		}
+
+		if (uchOption == uchCode && nLen >= 1)
+		{
+			return pOptions[i+2];
+		}
+
+		i += 2+nLen;
+	}
+
+	return 0;
+}
+
+static u32 DHCPTraceOptionU32 (const u8 *pOptions, unsigned nOptionsSize, u8 uchCode)
+{
+	assert (pOptions != 0);
+
+	for (unsigned i = 0; i < nOptionsSize;)
+	{
+		u8 uchOption = pOptions[i];
+		if (uchOption == DHCP_OPTION_END)
+		{
+			break;
+		}
+		if (uchOption == DHCP_OPTION_PAD)
+		{
+			i++;
+			continue;
+		}
+		if (i+2 > nOptionsSize)
+		{
+			break;
+		}
+
+		unsigned nLen = pOptions[i+1];
+		if (i+2+nLen > nOptionsSize)
+		{
+			break;
+		}
+
+		if (uchOption == uchCode && nLen == 4)
+		{
+			const u8 *pValue = pOptions+i+2;
+			return   (u32) pValue[0]
+			       | (u32) pValue[1] << 8
+			       | (u32) pValue[2] << 16
+			       | (u32) pValue[3] << 24;
+		}
+
+		i += 2+nLen;
+	}
+
+	return 0;
+}
