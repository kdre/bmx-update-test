+	const TUSBDeviceDescriptor *pDeviceDesc = GetDevice ()->GetDeviceDescriptor ();
+	assert (pDeviceDesc != 0);
+
+	if (   pDeviceDesc->idVendor  == 0x2DC8
+	    && pDeviceDesc->idProduct == 0x3106)
+	{
+		CLogger::Get ()->Write (FromUSBPadXbox360, LogNotice,
+				      "8BitDo receiver revision %x",
+				      (unsigned) pDeviceDesc->bcdDevice);
+
+		// Match Linux xpad's initial player-identification command for
+		// this receiver. SetLEDMode (GamePadLEDModeOn1) would send 0x06.
+		DMA_BUFFER (u8, InitCommand, 3);
+		InitCommand[0] = 0x01;
+		InitCommand[1] = 0x03;
+		InitCommand[2] = 0x02;
+
+		if (!SendToEndpointOut (InitCommand, 3))
+		{
+			return FALSE;
+		}
+
+		if (pDeviceDesc->bcdDevice == 0x0100)
+		{
+			// The receiver first enumerates with bootstrap firmware 1.00,
+			// then disconnects and returns as 3107 (idle) or as the 1.14
+			// runtime device after pairing. Polling the bootstrap input
+			// endpoint produces transaction errors and can interfere with
+			// this mode switch. The LED command above is all it needs here.
+			CLogger::Get ()->Write (FromUSBPadXbox360, LogNotice,
+					      "Waiting for 8BitDo runtime re-enumeration");
+			return TRUE;
+		}
+	}
+	else if (!SetLEDMode ((TGamePadLEDMode) m_nDeviceNumber))
