+	    || pPayload[239] != 99)
+	{
+		return 0;
+	}
+
+	for (unsigned i = 240; i < nPayloadLen;)
+	{
+		u8 uchOption = pPayload[i];
+		if (uchOption == 255)
+		{
+			break;
+		}
+		if (uchOption == 0)
+		{
+			i++;
+			continue;
+		}
+		if (i+2 > nPayloadLen)
