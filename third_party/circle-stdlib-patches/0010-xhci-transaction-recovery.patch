+void CXHCIEndpoint::ProcessRecovery (void)
+{
+	CUSBRequest *pURB;
+	boolean bSoftRetry = FALSE;
+	boolean bGiveUp = FALSE;
+	unsigned nSoftRetry = 0;
+	unsigned nHardRecovery = 0;
+
+	m_SpinLock.Acquire ();
+	if (   !m_bRecoveryPending
+	    || m_bRecoveryRunning)
+	{
+		m_SpinLock.Release ();
+		return;
+	}
+
+	pURB = m_pURB[0];
+	if (pURB == 0)
+	{
+		m_bRecoveryPending = FALSE;
+		m_SpinLock.Release ();
+		return;
+	}
+
+	m_bRecoveryPending = FALSE;
+	m_bRecoveryRunning = TRUE;
+
+	TEndpointType Type = pURB->GetEndpoint ()->GetType ();
+	if (m_nHardRecoveryCount >= XHCI_MAX_HARD_RECOVERIES)
+	{
+		bGiveUp = TRUE;
+	}
+	else if (   !m_pDevice->IsSplit ()
+	    && (   Type == EndpointTypeBulk
+	        || Type == EndpointTypeInterrupt)
+	    && m_nSoftRetryCount < XHCI_MAX_SOFT_RETRIES)
+	{
+		bSoftRetry = TRUE;
+		nSoftRetry = ++m_nSoftRetryCount;
+	}
+	m_SpinLock.Release ();
+
+	assert (m_pXHCIDevice);
+	assert (m_pDevice);
+	assert (XHCI_IS_ENDPOINTID (m_uchEndpointID));
+
+	if (bSoftRetry)
+	{
+		int nResult = m_pXHCIDevice->GetCommandManager ()->ResetEndpoint (
+							m_pDevice->GetSlotID (),
+							m_uchEndpointID, TRUE);
+		if (XHCI_CMD_SUCCESS (nResult))
+		{
+			m_SpinLock.Acquire ();
+			m_bRecoveryRunning = FALSE;
+			m_SpinLock.Release ();
+
+			CLogger::Get ()->Write (From, LogNotice,
+					      "Soft retry %u on endpoint %u",
+					      nSoftRetry, (unsigned) m_uchEndpointID);
+
+			DataSyncBarrier ();
+			m_pMMIO->db_write32 (m_pDevice->GetSlotID (),
+					     XHCI_REG_DB_TARGET_EP0 + m_uchEndpointID-1);
+			return;
+		}
+
+		CLogger::Get ()->Write (From, LogWarning,
+				      "Soft retry command failed on endpoint %u (%d)",
+				      (unsigned) m_uchEndpointID, nResult);
+	}
+
+	boolean bReset = FALSE;
+	if (!bGiveUp)
+	{
+		m_SpinLock.Acquire ();
+		nHardRecovery = ++m_nHardRecoveryCount;
+		m_SpinLock.Release ();
+
+		CLogger::Get ()->Write (From, LogWarning,
+				      "Hard recovery %u on endpoint %u",
+				      nHardRecovery, (unsigned) m_uchEndpointID);
+		bReset = ResetFromHalted ();
+	}
+	else
+	{
+		CLogger::Get ()->Write (From, LogError,
+				      "Giving up on endpoint %u after %u hard recoveries",
+				      (unsigned) m_uchEndpointID, m_nHardRecoveryCount);
+	}
+
+	m_SpinLock.Acquire ();
+	CUSBRequest *pFailedURB = m_pURB[0];
+	CUSBRequest *pQueuedURB = m_pURB[1];
+	m_pURB[0] = 0;
+	m_pURB[1] = 0;
+	m_bRecoveryPending = FALSE;
+	m_bRecoveryRunning = FALSE;
+	m_nSoftRetryCount = 0;
+	if (!bReset)
+	{
+		m_bValid = FALSE;
+	}
+	m_SpinLock.Release ();
+
+	if (   !bReset
+	    && !bGiveUp)
+	{
+		CLogger::Get ()->Write (From, LogError, "Cannot recover endpoint %u",
+					(unsigned) m_uchEndpointID);
+	}
+
+	if (pFailedURB != 0)
+	{
+		pFailedURB->SetStatus (0);
+		pFailedURB->SetUSBError (USBErrorTransaction);
+		pFailedURB->CallCompletionRoutine ();
+	}
+
+	if (pQueuedURB != 0)
+	{
+		pQueuedURB->SetStatus (0);
+		pQueuedURB->SetUSBError (USBErrorAborted);
+		pQueuedURB->CallCompletionRoutine ();
+	}
+}
