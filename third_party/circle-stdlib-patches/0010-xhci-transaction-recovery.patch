+void CXHCIDevice::ProcessRecoveries (void)
+{
+	if (   m_bShutdown
+	    || !m_bInitialized)
+	{
+		return;
+	}
+
+	m_RecoverySpinLock.Acquire ();
+	if (m_bProcessingRecoveries)
+	{
+		m_RecoverySpinLock.Release ();
+		return;
+	}
+	m_bProcessingRecoveries = TRUE;
+	m_RecoverySpinLock.Release ();
+
+	assert (m_pSlotManager != 0);
+	m_pSlotManager->ProcessRecoveries ();
+
+	m_RecoverySpinLock.Acquire ();
+	m_bProcessingRecoveries = FALSE;
+	m_RecoverySpinLock.Release ();
+}
