+	DMA_BUFFER (u8, MagicMessage, 20);
+	int nResult = GetHost ()->ControlMessage (GetEndpoint0 (),
+						 REQUEST_IN | REQUEST_VENDOR | REQUEST_TO_INTERFACE,
+						 0x01, 0x0100, 0x0000,
+						 MagicMessage, 20);
+	CLogger::Get ()->Write (FromUSBPadXbox360,
+				nResult < 0 ? LogWarning : LogNotice,
+				"XInput magic control request returned %d bytes", nResult);
+
+	return TRUE;
 }
 
