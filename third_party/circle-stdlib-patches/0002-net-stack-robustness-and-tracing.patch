+void CDHCPClient::WaitForLink (void)
+{
+	boolean bLogged = FALSE;
+	while (!IsLinkReady ())
+	{
+		if (!bLogged)
+		{
+			CLogger::Get ()->Write (FromDHCPClient, LogNotice,
+						"Link down. Waiting for link.");
+			bLogged = TRUE;
+		}
+
+		CScheduler::Get ()->MsSleep (100);
+	}
+
+	if (bLogged)
+	{
+		CLogger::Get ()->Write (FromDHCPClient, LogNotice,
+					"Link ready. Restarting discovery.");
+	}
+}
+
+void CDHCPClient::FlushSocket (void)
+{
+	unsigned nDropped = 0;
+	u8 Buffer[DHCP_MAX_MESSAGE_SIZE];
+	while (m_Socket.Receive (Buffer, sizeof Buffer, MSG_DONTWAIT) > 0)
+	{
+		nDropped++;
+		CScheduler::Get ()->Yield ();
+	}
+
+	if (nDropped > 0)
+	{
+		BMX_DHCP_LOG ("flushed %u queued messages", nDropped);
+	}
+}
